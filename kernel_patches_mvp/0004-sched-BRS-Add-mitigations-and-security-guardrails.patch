// --- Aging guardrail / starvation shield (Section IV-F) ---
// Absolute-starvation protection referenced by patch 0002: any runnable task
// whose undispatched wait exceeds S_max (100 ms) is force-promoted regardless
// of its interactivity score, then re-armed. Together with the safe-box
// projection this bounds the starvation rate S and is the boundedness
// assumption (A1) underpinning the mean-square stability result (Theorem 1).

#define SCHED_BRS_STARVE_NS (100ULL * NSEC_PER_MSEC) // S_max = 100 ms

// Called at pick time before the interactivity-aware tie-break. Returns a task
// that must be dispatched immediately, or NULL if none is starving.
static inline struct task_struct *sched_brs_starvation_shield(struct run_queue *rq,
                                                              u64 now_ns)
{
    struct task_struct *victim = NULL;
    u64 worst_wait = SCHED_BRS_STARVE_NS;

    list_for_each_entry(task, &rq->tasks, run_list) {
        u64 wait = now_ns - task->se.brs_last_queued_ns;
        if (wait > worst_wait) {   // pick the most-starved runnable task
            worst_wait = wait;
            victim = task;
        }
    }
    if (victim) {
        // Force-promote: pull vruntime to the runqueue minimum so the task is
        // selected now; re-arm its wait clock on dispatch.
        victim->se.vruntime = rq->min_vruntime;
        victim->se.brs_last_queued_ns = now_ns;
    }
    return victim;
}
