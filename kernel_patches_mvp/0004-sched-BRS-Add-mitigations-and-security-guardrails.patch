// File: kernel_patches_mvp/0004-sched-brs-Add-mitigations-and-security-guardrails.patch
// This patch implements safety and reliability features described in Section G (Mitigations)
// to prevent denial-of-service (DoS) and timing side-channel attacks.

#include <linux/sched_brs.h>
#include <linux/proc_fs.h>

// Safe range caps (per-mille fixed-point, matching Table I).
#define SCHED_BRS_ALPHA_MIN_CAP 100 // 0.10 min
#define SCHED_BRS_ALPHA_MAX_CAP 350 // 0.35 max
#define SCHED_BRS_BETA_MIN_CAP   50 // 0.05 min
#define SCHED_BRS_BETA_MAX_CAP  300 // 0.30 max

// Function to enforce parameter caps and safe ranges for /proc writes
static int sched_brs_proc_write_handler(struct ctl_table *table, int write, 
                                        void __user *buffer, size_t *len, loff_t *ppos)
{
    int ret;
    u32 val;
    
    // Use the standard handler to read/write the raw value
    ret = proc_dointvec(table, write, buffer, len, ppos);
    if (ret || !write)
        return ret;

    // Post-write validation and clamping based on the parameter key.
    // "Writes outside safe ranges are rejected/clamped and logged."
    val = *(u32 *)table->data;

    if (strcmp(table->procname, "bias_alpha") == 0) {
        if (val < SCHED_BRS_ALPHA_MIN_CAP || val > SCHED_BRS_ALPHA_MAX_CAP) {
            printk(KERN_WARNING "SCHED_BRS: bias_alpha %u out of [%u,%u]; clamping.\n",
                   val, SCHED_BRS_ALPHA_MIN_CAP, SCHED_BRS_ALPHA_MAX_CAP);
            *(u32 *)table->data = clamp_t(u32, val, SCHED_BRS_ALPHA_MIN_CAP,
                                          SCHED_BRS_ALPHA_MAX_CAP);
        }
    } else if (strcmp(table->procname, "bias_beta") == 0) {
        if (val < SCHED_BRS_BETA_MIN_CAP || val > SCHED_BRS_BETA_MAX_CAP) {
            printk(KERN_WARNING "SCHED_BRS: bias_beta %u out of [%u,%u]; clamping.\n",
                   val, SCHED_BRS_BETA_MIN_CAP, SCHED_BRS_BETA_MAX_CAP);
            *(u32 *)table->data = clamp_t(u32, val, SCHED_BRS_BETA_MIN_CAP,
                                          SCHED_BRS_BETA_MAX_CAP);
        }
    }

    return 0;
}

// Security Mitigation: Add bias jitter under high contention (Simplified Pseudo-code)
static u64 sched_brs_apply_security_jitter(u64 score)
{
    // "add bias jitter under high contention to reduce fingerprinting"
    
    // Check if the runqueue is under high load (contention)
    if (unlikely(sched_brs_params.jain_index < SCHED_BRS_JAIN_MITIGATION_LEVEL)) {
        // Apply small, randomized jitter to the scheduling score
        u64 jitter = get_random_u32() % SCHED_BRS_JITTER_MAX;
        if (score > jitter)
            score -= jitter;
        else
            score = 0; // Prevent overflow/underflow confusion
    }
    return score;
}

